# PrintFarm Bridge — environment variables
# Copy to .env and fill in values

# URL of the main PrintFarm API
API_URL=http://localhost:3000

# Secret token shared between Bridge and API (set BRIDGE_TOKEN in API too)
# Must match BRIDGE_TOKEN in apps/api/.env
BRIDGE_TOKEN=change-me-to-a-long-random-secret

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Enable camera frame capture (requires opencv-python-headless)
CAMERA_ENABLED=true

# Seconds between camera frames sent to AI service
CAMERA_INTERVAL_SECONDS=10

# JSON array of printers — fill in your printer details
# serial: from printer Settings > Device > Serial number
# ip: LAN IP (set static lease in router)
# access_code: 8-digit code from printer Settings > Network > Access Code
# device_id: UUID from PrintFarm DB (printers table)
PRINTERS=[
  {
    "serial": "00M09A123456789",
    "ip": "192.168.1.10",
    "access_code": "12345678",
    "device_id": "uuid-from-printfarm-db"
  }
]

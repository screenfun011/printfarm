# Kopiraj ovaj fajl u .env.local i popuni vrednosti
# .env.local se ne commituje (u .gitignore)

# Override za razvoj — ovde stavljaš prave API ključeve
# Sve što je ovde pregazuje docker-compose.yml environment

# Stripe (https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (https://resend.com/api-keys)
RESEND_API_KEY=re_...

# Opciono: drugačiji JWT secret
# JWT_SECRET=tvoj-secret-minimum-32-karaktera
